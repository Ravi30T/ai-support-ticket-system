# Server Configuration
PORT=3000

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/support-tickets
DB_NAME=support_ticket_system

# Security
JWT_SECRET=your_jwt_secret_key_here

# AI Service (Google Gemini API)
# Get a key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Email Notification Service (Nodemailer / Resend or SMTP provider)
# If using standard SMTP / Gmail:
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_app_password_here

# (Optional) Resend API Key if used by the application
RESEND_API_KEY=re_your_resend_api_key_here
